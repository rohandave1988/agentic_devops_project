LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
# Tool use requires a model with function calling: mistral-nemo, llama3.1, qwen2.5
OLLAMA_MODEL=mistral-nemo

# Only needed when LLM_BACKEND=claude
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# Prometheus + Grafana are on NodePort — no port-forward needed
PROMETHEUS_URL=http://localhost:30090
# Loki needs a port-forward — scripts/run.sh handles this automatically
LOKI_URL=http://localhost:3100

KUBE_CONTEXT=kind-devops-agent
TARGET_NAMESPACE=demo
TARGET_DEPLOYMENT=buggy-app

SLO_ERROR_RATE_THRESHOLD=0.01
SLO_4XX_RATE_THRESHOLD=0.05
SLO_LATENCY_P99_MS=200
SLO_LATENCY_P50_MS=50
SLO_CPU_THRESHOLD=0.80
SLO_CPU_THROTTLE_THRESHOLD=0.25
SLO_MEMORY_THRESHOLD=0.60
SLO_OOM_KILLS_THRESHOLD=0
SLO_ACTIVE_REQUESTS_MAX=50

AGENT_POLL_INTERVAL_SEC=10
COOLDOWN_PERIOD_SEC=120
DRY_RUN=false
MIN_REPLICAS=1
MAX_REPLICAS=6
ROLLBACK_MIN_CONFIDENCE=0.6

HUMAN_IN_LOOP=false
HUMAN_REVIEW_TIMEOUT_SEC=60

# Slack HITL (optional — only used when HUMAN_IN_LOOP=true)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_CHANNEL=#devops-alerts

AGENT_METRICS_PORT=8080
VERIFY_DELAY_SEC=90
DB_PATH=/tmp/agent.db
INCIDENT_HISTORY_LIMIT=50

# Langfuse LLM tracing (optional)
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000

# OpenTelemetry → Jaeger (optional)
# OTLP_ENDPOINT=localhost:4317

# ── Code patch + PR + deploy (agentic code-level remediation) ─────────────────
# Enable the agent to generate code patches and open GitHub PRs.
# Requires: gh auth login (run once in terminal)
ALLOW_CODE_PATCHES=true
# Also build the patched image and deploy it automatically after the PR is opened.
AUTO_DEPLOY_PATCH=true
# Minimum LLM confidence required before a patch is committed (default: 75%).
PATCH_MIN_CONFIDENCE=0.75
# Git branch prefix for agent-generated patches.
PATCH_BRANCH_PREFIX=agent-fix
# Target branch for PRs (main or master).
DEFAULT_BRANCH=main
